---
// biome-ignore-all lint/correctness/noUnusedVariables: Astro template consumes frontmatter metadata values.
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
  ogType?: "website" | "article";
  robots?: string;
}

const siteUrl = "https://wanderaware.com";
const {
  title,
  description = "RFID-based supplemental wandering alerts for adult day care centers.",
  canonical = `${siteUrl}${Astro.url.pathname}`,
  ogImage = "/assets/hero-lifestyle.jpg",
  ogImageAlt = "WanderAware supplemental wandering alerts for adult day care",
  ogImageWidth = 1200,
  ogImageHeight = 630,
  ogType = "website",
  robots,
} = Astro.props as Props;

const resolvedOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/logo.png" />
    <meta name="theme-color" content="#176E68" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,600;0,700;0,800;1,400;1,700&family=DM+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
